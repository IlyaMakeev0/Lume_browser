{
  "name": "lume",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:windows:x64": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1 -Target x86_64-pc-windows-msvc",
    "build:windows:arm64": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1 -Target aarch64-pc-windows-msvc",
    "build:android": "powershell -ExecutionPolicy Bypass -File scripts/build-android.ps1 -InitIfMissing",
    "build:macos:intel": "bash scripts/build-macos.sh x86_64-apple-darwin",
    "build:macos:apple": "bash scripts/build-macos.sh aarch64-apple-darwin",
    "build:ios": "bash scripts/build-ios.sh",
    "tauri:android:init": "tauri android init",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "tauri:ios:init": "tauri ios init",
    "tauri:ios:dev": "tauri ios dev",
    "tauri:ios:build": "tauri ios build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.2",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3"
  }
}
